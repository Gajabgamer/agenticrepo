# Auth.js / NextAuth
NEXTAUTH_URL=https://your-vercel-project.vercel.app
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# GitHub OAuth login
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_app_client_secret

# GitHub App automation
GITHUB_APP_ID=your_github_app_id
GITHUB_CLIENT_ID=your_github_app_client_id_optional_fallback
GITHUB_CLIENT_SECRET=your_github_app_client_secret_optional_fallback
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_TOKEN=optional_classic_or_fine_grained_token_for_local_fallback

# Turso / libSQL
DATABASE_URL=libsql://agentic-repo-gajabgamer.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your_turso_database_auth_token

# IBM Bob
BOB_API_KEY=your_bob_api_key

# Groq
GROQ_API_KEY=your_groq_api_key

# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-vercel-project.vercel.app
